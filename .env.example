# ── Exercise media provider ───────────────────────────────────────────────────
# Controls which exercise media source the app uses.
# Options:
#   static  — local images + hardcoded form cues (default, no API key needed)
#   ymove   — YMove licensed media (requires YMOVE_API_KEY below)
EXPO_PUBLIC_MEDIA_PROVIDER=static

# ── YMove integration ─────────────────────────────────────────────────────────
# Only required when EXPO_PUBLIC_MEDIA_PROVIDER=ymove.
# Leave commented out (or absent) when using the static provider.
# For EAS builds, add this as an EAS secret instead of committing it here.
# YMOVE_API_KEY=your_api_key_here

# ── Server (development only) ─────────────────────────────────────────────────
# PORT=5000
# NODE_ENV=development
